<!DOCTYPE html> <% root_settings = root_settings_snapshot() %>
<html lang="en" data-theme={root_theme_attribute(root_settings)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Allbert Assist" suffix="">
      {assigns[:page_title]}
    </.live_title>
    <meta
      name="description"
      content="Allbert is a personal assistant runtime that grows with you — local-first, inspectable, and yours."
    />
    <link rel="canonical" href={url(~p"/")} />
    <link rel="icon" type="image/svg+xml" href={~p"/images/allbert-mark.svg"} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Allbert" />
    <meta
      property="og:description"
      content="A personal assistant runtime that grows with you — local-first, inspectable, and yours."
    />
    <meta property="og:url" content={url(~p"/")} />
    <meta property="og:image" content={url(~p"/images/allbert-og.svg")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Allbert" />
    <meta
      name="twitter:description"
      content="A personal assistant runtime that grows with you — local-first, inspectable, and yours."
    />
    <meta name="twitter:image" content={url(~p"/images/allbert-og.svg")} />
    <link
      phx-track-static
      rel="stylesheet"
      href={~p"/assets/css/app.css?#{[v: static_asset_version()]}"}
    />
    <link rel="stylesheet" href={~p"/theme/user.css?#{[v: theme_asset_version()]}"} />
    <link rel="stylesheet" href={~p"/theme/snippets.css?#{[v: theme_asset_version()]}"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body
    data-high-contrast={root_high_contrast_attribute(root_settings)}
    data-reduce-motion={root_reduce_motion_attribute(root_settings)}
  >
    {@inner_content}
  </body>
</html>
