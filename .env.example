# Optional live-provider verification
# Used by ignored live smoke tests and manual provider verification.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_BOOTSTRAP=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional local Ollama override. Fresh profiles default to this URL and
# require no API key. Allbert does not install Ollama or pull models.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional alternate profile root for smokes
ALLBERT_HOME=

# Copy this file locally if helpful, but do not commit populated secrets.

# Optional Telegram testing note:
# Telegram testing uses filesystem-backed secrets/config, not env vars by default.
# See README.md and docs/onboarding-and-operations.md for:
#   ~/.allbert/secrets/telegram/bot_token
#   ~/.allbert/config/channels.telegram.allowed_chats
# Those checks are optional and are not part of the default contributor green path.
