#!/bin/sh
# v0.62 M1 release environment defaults.
# erlexec's port program requires SHELL and kills the node without it (M0
# spike finding) — launchd/systemd daemons have empty environments.
export SHELL="${SHELL:-/bin/sh}"
# Keep the release node non-distributed by default; the attach transport is a
# Unix-domain socket (v0.62 plan, Attach Transport Contract), not Erlang
# distribution.
export RELEASE_DISTRIBUTION="${RELEASE_DISTRIBUTION:-none}"
