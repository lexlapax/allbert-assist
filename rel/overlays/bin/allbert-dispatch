#!/bin/sh
# v0.62 M3 (M8.6): the operator dispatcher launcher. The M8.6 release step
# installs this file AS `bin/allbert` (the entry installer/formula/service/smoke
# invoke) and renames the generated OTP launcher to `bin/allbert-release`, which
# this wrapper calls for the release verbs (start/eval/rpc/…). So `allbert
# <group> <command>` reaches the unified dispatcher; serve maps to a foreground
# start; everything else runs the pure dispatcher via `eval` and exits on its
# code.
set -eu
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
RELEASE_BIN="$SELF_DIR/allbert-release"

case "${1:-}" in
  start|stop|restart|remote|rpc|eval|pid|daemon|version|versions|reboot)
    exec "$RELEASE_BIN" "$@" ;;
  serve)
    shift
    # M5: foreground serve boots the tree with the web endpoint enabled and
    # holds the single-writer lock and attach listener for subsequent commands.
    PHX_SERVER=true ALLBERT_HOLD_WRITER_LOCK=1 exec "$RELEASE_BIN" start "$@" ;;
  *)
    # Pass argv to the pure dispatcher; it prints and halts on its own code.
    exec "$RELEASE_BIN" eval "AllbertAssist.CLI.main(System.argv())" "$@" ;;
esac
