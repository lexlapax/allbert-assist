#!/bin/sh
# v0.62 M3: the operator dispatcher launcher. `bin/allbert` (generated by the
# release) handles start/eval/rpc/remote; this wrapper is what the install
# symlink / Homebrew bin points at, so `allbert <group> <command>` reaches the
# unified dispatcher. serve maps to a foreground/daemon start; everything else
# runs the pure dispatcher via `eval` and exits on its code.
set -eu
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
RELEASE_BIN="$SELF_DIR/allbert"

case "${1:-}" in
  start|stop|restart|remote|rpc|eval|pid|daemon|version|versions|reboot)
    exec "$RELEASE_BIN" "$@" ;;
  serve)
    shift
    # M5: foreground serve boots the tree with the web endpoint enabled and
    # holds the single-writer lock (so a second `allbert` command refuses).
    PHX_SERVER=true ALLBERT_HOLD_WRITER_LOCK=1 exec "$RELEASE_BIN" start "$@" ;;
  *)
    # Pass argv to the pure dispatcher; it prints and halts on its own code.
    exec "$RELEASE_BIN" eval "AllbertAssist.CLI.main(System.argv())" "$@" ;;
esac
